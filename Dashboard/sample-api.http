### Base URL
@baseUrl = http://127.0.0.1:8000/api
@json = application/json

### Delivery centers
POST {{baseUrl}}/centers
Content-Type: {{json}}

{
  "name": "Manhattan North Hub",
  "latitude": 40.7831,
  "longitude": -73.9712
}

###
GET {{baseUrl}}/centers

### Vehicles
POST {{baseUrl}}/vehicles
Content-Type: {{json}}

{
  "name": "Sprinter M-12",
  "capacity": 12,
  "average_speed": 30,
  "is_available": true,
  "delivery_center_id": 1
}

###
PATCH {{baseUrl}}/vehicles/1
Content-Type: {{json}}

{
  "is_available": true,
  "average_speed": 28
}

###
GET {{baseUrl}}/vehicles

### Orders (nearest center auto-assigned)
POST {{baseUrl}}/orders
Content-Type: {{json}}

{
  "address": "350 5th Ave, New York",
  "latitude": 40.7484,
  "longitude": -73.9857,
  "priority": "high"
}

###
GET {{baseUrl}}/orders?per_page=10&status=pending

###
PATCH {{baseUrl}}/orders/1
Content-Type: {{json}}

{
  "status": "delivered"
}

### Route generation (optional delivery_center_id; omit to process all centers with pending work)
POST {{baseUrl}}/routes/generate
Content-Type: {{json}}

{
  "delivery_center_id": 1,
  "departure_at": "2026-05-02T08:00:00-04:00"
}

###
POST {{baseUrl}}/routes/regenerate/1

###
GET {{baseUrl}}/routes

###
GET {{baseUrl}}/routes/1

### Simulation
POST {{baseUrl}}/routes/1/start
###
POST {{baseUrl}}/routes/1/next-stop
###
POST {{baseUrl}}/routes/1/complete
