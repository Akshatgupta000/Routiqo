APP_NAME=Routiqo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api-domain.railway.app

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mongodb
MONGODB_URI=
MONGODB_DATABASE=

SESSION_DRIVER=file
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-dashboard.vercel.app,https://your-landing.vercel.app

# Sanctum — comma-separated list of stateful domains (without protocol)
SANCTUM_STATEFUL_DOMAINS=your-dashboard.vercel.app,your-landing.vercel.app

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD="your-app-password"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@routiqo.com"
MAIL_FROM_NAME="${APP_NAME}"
